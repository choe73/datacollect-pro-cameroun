# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=datacollect
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/datacollect

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

# API
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# External APIs
WORLD_BANK_API_URL=https://api.worldbank.org/v2
OPEN_DATA_CAMEROON_URL=https://cameroon.opendataforafrica.org/api
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
FAO_API_URL=https://fenixservices.fao.org/faostat/api/v1/en/data

# Render
RENDER_EXTERNAL_URL=

# Frontend
VITE_API_URL=http://localhost:8000
